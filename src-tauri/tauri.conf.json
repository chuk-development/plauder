{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plauder",
  "version": "0.3.0",
  "identifier": "dev.chuk.plauder",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plauder",
        "width": 940,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Voice dictation settings & history",
    "longDescription": "Plauder — WhisperFlow-style voice dictation for Linux. Settings, history, corrections and debug logs."
  }
}
